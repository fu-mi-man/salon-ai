{
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(docker compose:*)",
      "Bash(docker exec:*)",
      "Bash(gh api:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr review:*)",
      "Bash(gh pr view:*)",
      "Bash(gh search:*)",
      "Bash(git -C:*)",
      "Bash(git add:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git rebase:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(git worktree:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(tree:*)",
      "Read",
      "Skill(code-review:code-review)",
      "Skill(review-summary)",
      "WebFetch",
      "WebSearch",
      "Write"
    ],
    "deny": [
      "Bash(docker compose down -v:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)"
    ],
    "ask": [
      "Bash(gh pr close:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr merge:*)",
      "Bash(git commit:*)",
      "Bash(git merge:*)",
      "Bash(git push:*)"
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "code-review@claude-plugins-official": true
  }
}
